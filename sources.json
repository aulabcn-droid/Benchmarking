{
  "years": [2024, 2025, 2026],
  "metrics": [
    {
      "key": "ingresos",
      "label": "Ingresos",
      "unit": "€",
      "patterns": [
        "ingresos?\\s*[:\\-–]?\\s*([0-9][0-9\\.,]+)\\s*€",
        "([0-9][0-9\\.,]+)\\s*€\\s*(?:de\\s+ingresos)?"
      ],
      "year_patterns": [
        "{year}.{0,60}?ingresos?\\s*[:\\-–]?\\s*([0-9][0-9\\.,]+)\\s*€",
        "ingresos?.{0,60}?{year}.{0,30}?([0-9][0-9\\.,]+)\\s*€"
      ]
    },
    {
      "key": "personal",
      "label": "Personal",
      "unit": "",
      "patterns": [
        "(\\d{1,4})\\s*(?:empleados|personal|personas|trabajadores)",
        "personal\\s*[:\\-–]?\\s*(\\d{1,4})"
      ],
      "year_patterns": [
        "{year}.{0,60}?personal\\s*[:\\-–]?\\s*(\\d{1,4})",
        "personal.{0,60}?{year}.{0,30}?(\\d{1,4})"
      ]
    },
    {
      "key": "viviendas",
      "label": "Viviendas",
      "unit": "",
      "patterns": [
        "(\\d{1,4})\\s*(?:viviendas|hogares|pisos|alojamientos|apartamentos)",
        "viviendas\\s*[:\\-–]?\\s*(\\d{1,4})"
      ],
      "year_patterns": [
        "{year}.{0,60}?viviendas\\s*[:\\-–]?\\s*(\\d{1,4})",
        "viviendas.{0,60}?{year}.{0,30}?(\\d{1,4})"
      ]
    }
  ],
  "sources": [
    {
      "nombre": "Som Llar",
      "url": "https://somllar.example.org/transparencia"
    },
    {
      "nombre": "Habitat3",
      "url": "https://www.habitat3.cat/transparencia"
    },
    {
      "nombre": "Mambré",
      "url": "https://fundaciomambre.org/ca/transparencia/"
    },
    {
      "nombre": "FFHS",
      "url": "https://ffhs.example.org/transparencia/"
    },
    {
      "nombre": "Provivienda",
      "url": "https://www.provivienda.org/transparencia/"
    }
  ]
}
